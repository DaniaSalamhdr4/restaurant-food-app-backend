const mongoose = require("mongoose");

//schema
const userSchema = new mongoose.Schema(
  {
    userName: {
      type: String,
      required: [true, `user name is required`],
    },
    email: {
      type: String,
      required: [true, `email is required`],
      unique: true,
    },
    password: {
      type: String,
      required: [true, `password is required`],
    },
    address: {
      type: Array,
    },
    phone: {
      type: String,
      required: [true, `phone number is required`],
    },
    userType: {
      type: String,
      required: [true, `user type is required`],
      default: "client",
      enum: ["client", "admin", "vendoe", "driver"],
    },
    profile: {
      type: String,
      default:
        "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSFqfsYcDbQRLzQd-cr5udnA5ev-Kq-ZfCQtkU2O-bfWDfXY4CFFnRw-ZA&s=10",
    },
  },
  {
    timestamps: true,
  },
);

//export
module.exports = mongoose.model('User',userSchema)